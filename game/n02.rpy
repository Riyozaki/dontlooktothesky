################################################################################
## Нейтральный маршрут — N02 «Двенадцать минут»
################################################################################

label n02:
    $ save_name = "Нейтральный маршрут — N02"
    call n02_s01
    call n02_s02
    call n02_s03
    call n02_s04
    call n02_s05
    call n02_s06
    call n02_s07
    call n02_s08
    return


################################################################################
## N02-S01 — «До перезаписи»
################################################################################

label n02_s01:
    scene bg pharmacy rain
    with fade
    play music neutral_paper_trace fadein 0.8

    show alex neutral at alex_left
    show lena neutral at sprite_right
    with dissolve

    narrator "К аптеке они пришли без пяти одиннадцать. Дождь закончился ночью, вывеска отражалась в лужах у входа. Управляющий ждал в подсобном помещении с ноутбуком и внешним диском."

    narrator "По дороге Лена дважды проверила ответ сервисного центра. Служба безопасности сохранила вчерашнюю запись, но выдавать её без заявления отказалась. Сначала предстояло закрепить старый архив аптеки, который исчезал этой ночью."

    narrator "Подсобка помещала один стул и узкий металлический шкаф. Александр остался у двери. Лена поставила сумку на свободный край стола так, чтобы накопители не касались хозяйского ноутбука."

    "Управляющий" "Вы просили сохранить два промежутка. Авария и вчерашний сбой у оператора. Второй архив принадлежит другому зданию."

    l "По второму уже отправлен запрос. Здесь нужен исходный файл аварии и сведения регистратора."

    "Управляющий" "В прошлый раз вам хватило ссылки."

    a "Тогда мы искали машину. Теперь нужно подтвердить происхождение записи и скачка времени."

    "Управляющий" "Я могу подтвердить файл. Причину скачка не знаю."

    l "Этого достаточно."

    "Управляющий" "Вы оба участники аварии?"

    a "Я был у дороги. Лена забрала заказ после."

    l "Мы восстанавливаем цепочку предметов и время. Оценивать причину вас не просим."

    "Управляющий" "Тогда укажите это в получении. Я не хочу оказаться свидетелем того, чего камера не сняла."

    narrator "Лена добавила к форме: управляющий подтверждает происхождение файла и состояние оборудования, очевидцем аварии не является. Он прочитал строку и кивнул."

    narrator "Управляющий достал журнал обслуживания. Последний ремонт проводили за три месяца до аварии. В нужный день не было перезапуска, отключения питания или ручной смены часов. После скачка регистратор продолжил работу с прежней погрешностью."

    l "Можно сфотографировать эту строку?"

    "Управляющий" "Закройте остальные записи."

    narrator "Он положил лист поверх разворота. Лена сняла только дату и состояние оборудования, затем показала экран владельцу."

    a "Другие камеры тоже потеряли время?"

    "Управляющий" "Кассовая метка перескочила одновременно. Покупатели в кадре двигались обычно. Видео из зала не отдам."

    l "Запишите факт в комментарии. Лица клиентов нам не нужны."

    narrator "Он открыл локальный архив. На экране появилась остановка под дождём и метка 18:33. Прежняя копия выглядела так же, но теперь рядом стояли модель регистратора и внутренний номер камеры."

    narrator "Управляющий запустил запись за пять минут до аварии. Возле аптеки прошли два покупателя, автобус закрыл остановку и уехал. Александр появился на дальнем краю кадра вместе с велосипедом."

    l "Остановите перед скачком."

    narrator "На последнем кадре машина ещё стояла у поворота. Мираэль отсутствовала. Александр находился на дороге, пакет — под клапаном рюкзака."

    l "Теперь следующий кадр."

    narrator "Время перескочило. Машина исчезла, велосипед лежал за бордюром. Светлый силуэт находился возле Александра. Между кадрами не было чёрного экрана или ошибки чтения."

    "Управляющий" "Вот поэтому я сказал, что часы исправились. Изображение идёт подряд."

    a "После скачка часы снова отстают так же?"

    "Управляющий" "Да. Через час погрешность та же."

    narrator "Лена записала номера соседних кадров и попросила управляющего подтвердить их в комментарии. Он сначала отказался оценивать последовательность, затем согласился указать только номера и метки."

    l "Нам не нужен ваш вывод. Нужен факт, что между ними нет другого сохранённого кадра."

    "Управляющий" "Это подтвержу."

    narrator "На внутренней кассовой камере в ту же границу покупатель держал кошелёк у терминала. После скачка карта уже находилась в его руке, а чек выходил из принтера. Управляющий не открыл изображение полностью, но внёс наблюдение в служебный комментарий."

    a "Можно выгрузить двадцать минут?"

    "Управляющий" "Для просмотра доступ давал. Про передачу в другое дело вы не говорили."

    l "Полиции пока нет. Мы собираем время происшествия. Если подадим официально, сообщим отдельно."

    "Управляющий" "Полный вечер не отдам. Сделаю отрезок и закрою посетителей."

    narrator "Полоса выгрузки дошла до двадцати процентов и остановилась с ошибкой. Управляющий попробовал снова."

    "Управляющий" "Сервер уже чистит старые блоки. Может не успеть."

    narrator "Ссылка на прежнюю копию оставалась открыта в телефоне Александра. Скачать файл можно было одним нажатием. Разрешение касалось просмотра, а ночь могла оставить их с пережатой версией без служебной отметки."

    menu:
        "Дождаться согласованного экспорта":
            $ n02_used_unapproved_copy = False
            $ neutral_witness_autonomy += 1

            narrator "Александр убрал телефон."

            a "Сократите интервал и повторите экспорт. Если не получится, зафиксируем ошибку и попросим разрешение на старую копию."

            "Управляющий" "Так дольше."

            a "Зато вы подтвердите именно тот файл, который отдали."

            narrator "Управляющий поставил границы в двадцать минут. Вторая выгрузка пошла без остановки."

        "Сохранить доступную копию сейчас":
            $ n02_used_unapproved_copy = True
            $ neutral_evidence_integrity += 1

            narrator "Александр нажал загрузку. Файл сохранился в локальную папку."

            a "Я сделал резервную копию по прежней ссылке. Не стану выдавать её за согласованный экспорт."

            "Управляющий" "Я разрешал посмотреть."

            a "Поэтому записываем способ получения и отдельно просим разрешение сохранить."

            narrator "Лена внесла действие в таблицу. Управляющий недовольно прочитал строку, но не потребовал удалить файл."

            "Управляющий" "Если мой экспорт завершится, работаете с ним. Эту оставляете резервной."

            a "Согласен."

    narrator "Экспорт закончился. Управляющий записал файл на чистый накопитель, распечатал сведения регистратора и поставил подпись возле времени выгрузки."

    narrator "Александр открыл прежнюю копию на отдельном устройстве. У неё было меньше разрешение и другой размер, но первый кадр перед скачком совпадал. Лена отметила: старая ссылка подтверждает раннее получение, новый экспорт содержит служебные данные."

    a "Старая копия теперь нужна?"

    l "Как подтверждение, что файл существовал до сегодняшнего запроса. Анализируем новый."

    "Управляющий" "Разрешаю использовать двадцатиминутный отрезок для проверки дорожного происшествия. Публикация лиц посетителей запрещена."

    narrator "Лена попросила его повторить формулировку на запись. После этого запечатала накопитель в прозрачный пакет. Александр расписался как получатель."

    narrator "В таблице происхождения появились имя управляющего, время экспорта и номер носителя. Лена сделала фотографию целой пломбы. Александр получил копию строки, оригинал остался на планшете без облачной синхронизации."

    a "Если пакет откроем для просмотра, пломба нарушится."

    l "Поэтому рабочую копию сделаем при владельце или запишем открытие отдельно. Сегодня смотрим на ноутбуке техника."

    "Управляющий" "На видео скачок времени. Регистратор иногда так делает после потери питания."

    a "Питание пропадало?"

    "Управляющий" "В журнале перезапуска нет. Камера старая, другого объяснения у меня нет."

    narrator "Он оставил номер для последующей проверки подписи и попросил обращаться днём, когда доступен журнал обслуживания. Лена внесла часы связи рядом с его именем."

    l "Поэтому берём вторую систему."

    $ n02_pharmacy_archive_preserved = True
    $ neutral_evidence_integrity += 1

    narrator "На улице Лена убрала пакет во внутренний карман сумки. Она сфотографировала пломбу ещё раз и отправила управляющему номер полученной копии. Тот подтвердил сообщением, что пакет покинул аптеку закрытым."

    a "Если потеряем его по дороге, останется переписка."

    l "Останется доказательство, что копия существовала. Сам файл придётся получать заново, пока архив жив."

    narrator "Они записали ближайший обратный маршрут на случай повреждения носителя."

    l "Теперь домофонная служба."

    a "Ты даже не хочешь посмотреть файл?"

    l "Посмотрим там, где владелец не ждёт за дверью, пока мы решим устройство времени."

    scene black
    stop music fadeout 0.8
    with dissolve
    return

################################################################################
## N02-S02 — «Другая система»
################################################################################

label n02_s02:
    scene bg client corridor
    with fade
    play music evidence_anxiety fadein 0.8

    show alex neutral at alex_left
    show lena neutral at sprite_right
    with dissolve

    narrator "Домофонная служба занимала комнату на первом этаже соседнего дома. Техник сидел за двумя мониторами и ел яблоко над открытой клавиатурой. Лена показала фотографию машины, найденную через этот архив несколькими днями раньше."

    "Техник" "Помню запрос. Вы искали номер по проезду во двор."

    l "Теперь нужен полный отрезок с 18:30 до 18:50 и подтверждение часов регистратора."

    "Техник" "Машину вы нашли?"

    a "Нашли. Водитель признал, что был на месте."

    "Техник" "Тогда зачем снова камера?"

    l "Время на аптечной записи перескочило. Хотим проверить систему с другим владельцем."

    narrator "Техник отложил яблоко и вытер руки салфеткой. После слова «время» просьба перестала быть обычным поиском номера."

    "Техник" "Наш регистратор не связан с аптекой. Даже интернет другой."

    l "Поэтому и пришли."

    narrator "Он открыл журнал прежнего обращения. В нём стояло имя Лены и причина сохранения: возможное дорожное происшествие. Александр в записи не упоминался."

    a "Можно добавить меня как участника запроса?"

    "Техник" "После паспорта. Тогда оба распишетесь в получении."

    narrator "Александр передал документ. Техник внёс его данные только в форму выдачи и вернул паспорт до открытия архива."

    "Техник" "Через неделю архив мог уйти."

    narrator "Он ввёл дату. Список остановился на последнем дне хранения. Нужный блок оставался в резервной копии из-за прежнего обращения Лены."

    "Техник" "Повезло. Сохранил, когда вы спрашивали машину."

    a "Время у камеры точное?"

    "Техник" "Отстаёт на минуту сорок две секунды. Давно. После синхронизации домофоны теряют метки, поэтому оставили как есть."

    narrator "Лена записала постоянную поправку. На экране машина появилась в 18:31 по внутренним часам, медленно прошла вдоль дома и повернула к перекрёстку. Велосипед Александра возник на дальнем краю позже."

    narrator "В 18:32:18 изображение перескочило. Дождь изменил направление, возле бордюра уже лежал велосипед. Машины в кадре не было."

    l "Добавляем минуту сорок две."

    narrator "После поправки граница становилась 18:34. Аптечный регистратор и домофон принадлежали разным владельцам. Один работал через локальный сервер, второй писал на сетевое хранилище."

    a "Одинаковый скачок."

    l "Одинаковая граница. Длина разрыва может отличаться."

    narrator "Техник запустил кадры медленнее. До границы автобус закрыл половину дороги, затем уехал. После скачка остановка была пустой, велосипед лежал у бордюра, а заднее колесо ещё вращалось."

    a "Оно не могло вращаться двенадцать минут."

    "Техник" "Если время действительно прошло — не могло."

    l "Значит, для камеры кадры соседние по движению и разделены по метке."

    narrator "На аптечной записи дождь после скачка шёл под другим углом и положение машин менялось сильнее. Домофон видел колесо, которое продолжало движение. Два файла по-разному описывали длительность одной границы."

    narrator "Лена поставила записи рядом и синхронизировала их по автобусу. На одном экране он проходил перед аптекой, на другом появлялся возле двора через обычные двадцать секунд. До 18:34 движение совпадало с постоянной поправкой. После скачка камеры снова расходились ровно на минуту сорок две."

    l "Погрешность не изменилась."

    "Техник" "Значит, часы домофона никто не правил."

    a "А двенадцать минут появились внутри файла."

    narrator "Лена сохранила снимок двух временных шкал. Техник подписал, что сравнение сделано на его рабочем месте с копией аптеки, которую они открыли без передачи ему файла."

    a "Будто время прошло для дороги и остановилось для велосипеда."

    l "Либо метка перескочила отдельно от кадров. Оставляем оба объяснения."

    "Техник" "Посмотрите на фонарь."

    narrator "Красный сигнал горел до скачка. На следующем кадре включился зелёный. Обычный цикл занимал меньше двух минут. В двенадцать минут помещалось несколько циклов, но камера сохранила только соседние состояния."

    l "Есть счётчик кадров?"

    "Техник" "Внутри файла. Пропуска нет. Номер увеличился на единицу."

    narrator "Он открыл свойства. Лена сфотографировала две строки после разрешения."

    a "Файл не потерял кусок."

    l "Он записал соседние изображения и назначил им разное время."

    narrator "Техник открыл журнал питания. Перерывов в нужный вечер не было. Камера продолжала отправлять служебный сигнал каждую минуту, хотя временная метка внутри видео перескочила."

    a "Служебный сигнал за двенадцать минут сохранился?"

    "Техник" "Да. Регистратор был в сети."

    l "Можно приложить журнал?"

    "Техник" "Если управляющая компания разрешит."

    narrator "Лена достала ответ на прежнее обращение. Владелец дома разрешал использовать кадры машины. Полный интервал туда не входил."

    a "Сколько проживёт резервная копия?"

    "Техник" "Сегодня не удалю. Завтра ничего не обещаю."

    narrator "Они позвонили управляющему. Тот предложил обращаться через полицию. Лена объяснила, что техник уже сохранил файл по их прежней просьбе и сейчас требуется расширить разрешённый промежуток."

    narrator "Через десять минут управляющий согласился на копию без звука и с закрытыми окнами жильцов. Техник поставил маску на верхнюю часть кадра, добавил журнал питания и выгрузил двадцать минут."

    narrator "Александр следил за полосой обработки. На этот раз доступ и разрешение появились в одном порядке."

    "Техник" "Подпишите получение. И если узнаете, почему часы прыгнули, скажите. У нас такого больше не было."

    l "Сообщим в пределах разрешения."

    $ n02_service_archive_preserved = True
    $ neutral_evidence_integrity += 1

    narrator "На выходе Александр остановился у домофона. Камера над дверью не могла подтвердить крылья. Зато видела велосипед до пустоты и после неё."

    "Техник" "На второй записи женщина есть?"

    a "Аптечная показывает светлый силуэт после скачка."

    l "Лица и момента появления нет. Поэтому файл подтверждает положение тела после интервала, а не происхождение Мираэль."

    "Техник" "Мираэль — это пострадавшая?"

    a "Да."

    narrator "Лена внесла имя только в свою заметку. В акте выдачи осталась формулировка «светлый силуэт»: техник не видел человека достаточно ясно."

    a "Две камеры потеряли границу."

    l "И обе сохранили соседние кадры."

    a "Этого хватит?"

    l "Для отсутствующего времени. Теперь покажем, что внутри происходили действия."

    "Техник" "Если подадите официально, укажите постоянное отставание часов. Без него записи выглядят разными."

    l "Приложим вашу подпись и журнал."

    narrator "Техник дал рабочий номер для проверки. Разрешил подтвердить оборудование и выдачу файла, но отказался обсуждать природу скачка."

    narrator "Она отметила на карте камеру, остановку и аптеку. Между точками оставалась дорога, которую записи перескочили без движения."

    narrator "Следующим слоем Лена добавила положение велосипеда до и после скачка. Александр подтвердил обе точки, но не подписывал причину перемещения до полевой проверки."

    scene black
    stop music fadeout 0.8
    with dissolve
    return

################################################################################
## N02-S03 — «То, что успело произойти»
################################################################################

label n02_s03:
    scene bg bus stop rain
    with fade
    play music neutral_paper_trace fadein 0.8

    show alex neutral at alex_left
    show lena neutral at sprite_right
    with dissolve

    narrator "К остановке они вернулись после обеда. Дорога высохла, автобусы шли по расписанию. Лена поставила планшет на скамью и открыла два кадра рядом."

    narrator "На первом Александр ещё ехал вдоль края дороги. Машина стояла у поворота. На втором велосипед лежал за бордюром, а Александр находился возле светлого силуэта."

    l "Рассказывай действия. Причину исчезновения времени пока не добавляем."

    a "Мираэль толкнула меня. Я упал сюда."

    narrator "Он показал участок у бордюра."

    a "Машина ударила её и остановилась дальше. Водитель вышел. Потом уехал."

    l "Велосипед?"

    a "Остался на дороге. Я оттащил его после второй машины."

    narrator "Лена отметила исходное положение и точку за бордюром. Поднять раму с ушибленным коленом занимало время."

    a "Потом записал номер. Проверил пульс, прижал куртку к ране и звонил 112."

    l "Порядок?"

    a "Пульс раньше записи. Вызов между ними или после — не уверен."

    narrator "Она оставила два варианта в одной строке."

    l "Дальше?"

    a "Перенёс её к аптеке."

    narrator "Они прошли от дороги до навеса. Александр вёл велосипед одной рукой и показывал, где останавливался. Без тела Мираэль путь занимал меньше двух минут. В тот вечер он шёл дольше."

    narrator "Лена включила секундомер только для расстояния. Получилось сто девять секунд. Она подписала результат: путь без пострадавшего, сухая дорога, исправная нога."

    a "В дождь останавливался у ограждения. Проверял дыхание, потом смотрел назад на машину."

    l "Машины уже не было?"

    a "Не было. Я всё равно смотрел."

    narrator "Они отметили два места остановки. На втором аптечная камера уже захватывала край тротуара, но движение попадало внутрь скачка."

    l "Где записал номер?"

    a "Возле дороги, до переноса. Рукав лежал на колене."

    l "Когда убрал пакет под рюкзак?"

    a "После записи. Потом доставал его, когда накрывал Мираэль от дождя."

    narrator "Лена добавила перемещения рукава. Они объясняли сухую середину бумаги и кровь на краю."

    l "Ты нёс её всё расстояние?"

    a "Часть тащил под плечами. Потом поднял. Крылья цеплялись за велосипед и рюкзак."

    narrator "Лена посмотрела на него и вернулась к карте. После сервисного центра крылья вошли в список возможных физических деталей, хотя сама она их не видела."

    l "У аптеки что изменилось?"

    a "Рана закрылась. Крылья исчезли. Время перескочило на 18:46."

    narrator "На аптечном кадре после скачка Александр уже стоял ближе к навесу. Велосипед находился у стены, светлый силуэт лежал на сухой полосе. Камера не показывала путь между точками."

    l "Минимум: убрать велосипед, записать номер, остановить кровь и перенести человека."

    a "Ещё попытки вызвать помощь."

    l "И дверь аптеки."

    narrator "Список вышел длиннее пустого промежутка на экране."

    narrator "Лена открыла фотографии следующего часа. На снимке из квартиры рукав уже лежал отдельно, куртка была в ванной, а пакет лекарств оставался запечатанным. Рабочая передача Лене произошла в 19:04."

    l "После 18:46 у тебя восемнадцать минут до передачи заказа. За это время вы дошли домой."

    a "Да. У аптеки Мираэль уже говорила и могла идти."

    l "Значит, перенос и первая помощь должны находиться до возврата времени. Иначе не помещается дорога домой."

    narrator "Она добавила нижнюю границу. Теперь действия поддерживались не только изменившимся положением предметов, но и первым обычным временем после интервала."

    a "Я помню всё это."

    l "Положение предметов подтверждает часть памяти. Время передачи ограничивает остальное."

    a "Четыре вызова остаются только моими словами."

    l "Оператор подтвердил отсутствие соединений. Количество пока оставляем твоим свидетельством."

    narrator "Александр хотел сделать строку увереннее. В памяти четыре попытки различались экраном и местом, но ни одна не получила внешней отметки. Он согласился с подписью Лены."

    l "Твои повреждения?"

    a "Колено и плечо от падения. Велосипед ушёл по асфальту, передний обод погнулся."

    l "Следов удара машины на велосипеде нет?"

    a "Мастер сказал, что колесо повело от падения и боковой нагрузки. Заключения не делал."

    narrator "Лена добавила адрес мастерской и пометила проверку на потом. Пока их файлы показывали, что велосипед двигался отдельно от машины, но не доказывали, какое тело приняло удар."

    l "Это понадобится после водителя."

    narrator "К остановке подошла Мираэль. Она заранее согласилась проверить телесный маршрут и оставила верхнее уведомление дома."

    show mirael neutral at sprite_center
    with dissolve

    m "Вы дошли до аптеки?"

    l "Да. Можно спросить о положении тела после удара?"

    m "Можно."

    l "Где вы пришли в сознание?"

    m "Под навесом. Голова лежала на свёрнутой ткани. Александр сидел рядом."

    a "Куртка была под плечами."

    m "Значит, ткань я помню неточно."

    l "Велосипед у стены помните?"

    m "Да. Переднее колесо задевало раму, когда Александр вёл его домой."

    l "Как оказались у аптеки?"

    m "Он перенёс меня. Само движение помню отдельными толчками."

    l "Помните остановку у ограждения?"

    m "Один раз открыла глаза. Видела мокрый рукав Александра и свет аптеки дальше по улице. Потом снова потеряла последовательность."

    a "Я думал, ты всё время была без сознания."

    m "Я не могла ответить. Это не означает полного отсутствия восприятия."

    narrator "Александр добавил собственную ошибку в заметку: состояние Мираэль оценивал по отсутствию ответа. Лена оставила рядом её версию."

    narrator "Лена записала слова Мираэль возле кадра, сохранив их отдельным свидетельством."

    m "Это войдёт в земное заявление?"

    l "Пока в нашу хронологию. Перед передачей покажем точную строку."

    m "Хорошо."

    narrator "Мираэль коснулась бока через одежду."

    a "Болит?"

    m "После долгой дороги. Сейчас терпимо."

    l "Тогда на сегодня хватит реконструкции с вами."

    narrator "Мираэль закрыла планшет ладонью и кивнула."

    m "Согласна."

    narrator "Она ушла к мосту."

    hide mirael
    with dissolve

    narrator "Лена открыла карту действий."

    l "Камеры перескочили из первого положения в последнее. Внутри есть работа, которую сделал живой человек."

    a "И раненый человек, которого он перенёс."

    l "Это подтвердят машина и кровь. Дальше нужен след удара."

    a "Так точнее."

    l "Записываю."

    $ n02_actions_inside_gap = True
    $ neutral_evidence_integrity += 1

    narrator "Вместо заголовка «потерянные двенадцать минут» Лена написала: «действия между соседними кадрами». Пустой интервал получил содержание, которое поддерживали предметы и положение тел."

    narrator "Она сделала фотографии каждой отмеченной точки с текущего угла и подписала, что снимки относятся к реконструкции через неделю. Александр отдельно подтвердил собственные остановки. Мираэль получит копию строки о переносе до внешней передачи."

    narrator "Время текущего прохода сохранили только как справку: сухая дорога и отсутствие пострадавшего делали прямое сравнение невозможным."

    scene black
    stop music fadeout 1.0
    with dissolve
