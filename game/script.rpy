################################################################################
## Точка входа и рабочая интерактивная разметка C00
################################################################################

label start:
    $ quick_menu = True
    call c00
    return


label c00:
    call c00_s01
    call c00_s02
    call c00_s03
    call c00_s04

    scene black
    with fade

    centered "Конец рабочего прототипа C00"
    centered "Следующий блок после утверждения художественного текста — C01."
    return


label c00_s01:
    scene bg alex room dawn
    with fade

    # TODO: заменить служебный текст художественной сценой объёмом около 500 слов.
    "Телефон вибрирует возле кровати. На экране — время начала смены и сообщение Дмитрия."
    "Александр проверяет будильник и видит, что отключил его сам."

    menu:
        "Ответить Дмитрию":
            $ c00_replied_to_dmitry = True
            $ alex_responsibility += 1
            a "Уже выхожу."

        "Оставить сообщение непрочитанным":
            $ c00_replied_to_dmitry = False
            "Александр убирает телефон. Ответ сейчас всё равно ничего не ускорит."

    play music city_day fadein 1.5
    "Он находит ключи во вчерашней куртке и выходит."
    return


label c00_s02:
    scene bg apartment entrance day
    with dissolve

    "В подъезде начинает расходиться молния рюкзака. Александр решает придержать её рукой."

    scene bg street day
    with dissolve

    "На улице из рюкзака выпадает упаковка салфеток."
    "Пока Александр возвращается за ней, впереди падает кусок штукатурки."
    "Он временно поправляет молнию и продолжает путь."
    return


label c00_s03:
    scene bg depot morning
    with dissolve
    play music delivery_day fadeout 0.8 fadein 1.0

    show dmitry serious at center

    if c00_replied_to_dmitry:
        d "Ты написал, что уже выходишь. Сколько времени у тебя занимает «уже»?"
    else:
        d "Рабочий чат ты тоже решил открыть после смены?"

    a "Маршрут закрою сегодня. Покажи адреса."
    "Александр быстро перестраивает порядок доставок. Дмитрий принимает расчёт и выдаёт заказы."

    hide dmitry
    show lena snide at center
    with dissolve

    l "Смотрю, утро у тебя опять началось ближе к обеду."
    a "Главное, что началось."

    hide lena
    return


label c00_s04:
    scene bg depot morning

    "В бумажной накладной указан другой адрес. Приложение уже отправило клиенту старые данные."

    menu:
        "Показать Дмитрию расхождение":
            $ c00_reported_manifest_error = True
            $ alex_responsibility += 1
            "Александр возвращает накладную Дмитрию. Исправление уходит в систему, но уведомление клиент уже получил."

        "Разобраться с адресом по дороге":
            $ c00_reported_manifest_error = False
            "Александр фотографирует накладную. Позвонить клиенту можно и позже."

    show lena neutral at center
    with dissolve
    l "Коробку придержишь?"

    menu:
        "Помочь Лене":
            $ c00_helped_lena = True
            $ lena_trust += 1
            "Александр придерживает упаковку, пока Лена закрепляет ленту."

        "Сослаться на плотный маршрут":
            $ c00_helped_lena = False
            a "Я и так уже опаздываю."
            l "Я заметила."

    hide lena
    "Александр закрепляет молнию рюкзака и подтверждает начало маршрута в приложении."
    stop music fadeout 1.0
    return
