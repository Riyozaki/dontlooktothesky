    $ save_name = "Маршрут Валерии — V07"
    call v07_s01
    call v07_s02
    call v07_s03
    call v07_s04
    call v07_s05
    call v07_s06
    call v07_s07
    call v07_s08
    call v07_s09
    call v07_s10
